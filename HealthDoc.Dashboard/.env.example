# Azure AD tenant ID (found in Azure Portal > Azure Active Directory > Overview)
VITE_TENANT_ID=

# App registration client ID for HealthDoc-Dashboard (the SPA)
VITE_SPA_CLIENT_ID=

# App registration client ID for HealthDoc-API (the backend API)
VITE_API_CLIENT_ID=

# APIM base URL for the Internal Dashboard product operations
VITE_APIM_BASE_URL=https://apim-healthdoc-dev.azure-api.net/labs
